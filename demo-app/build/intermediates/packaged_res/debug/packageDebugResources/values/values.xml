    <style name="BottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyleItem</item>
    </style>
    <style name="BottomSheetStyleItem" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>
    <style name="Theme.AtheerDemo" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/atheer_primary</item>
        <item name="colorPrimaryDark">@color/atheer_primary_dark</item>
        <item name="colorAccent">@color/atheer_accent</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/atheer_primary_dark</item>
        <item name="android:navigationBarColor">@color/atheer_primary_dark</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:layoutDirection">rtl</item>
    </style>
    <style name="Theme.AtheerDemo.AppBar" parent="ThemeOverlay.MaterialComponents.Dark.ActionBar">
        <item name="colorPrimary">@color/atheer_primary</item>
    </style>
    <style name="Theme.AtheerDemo.Splash" parent="Theme.AtheerDemo">
        <item name="android:windowBackground">@color/atheer_primary</item>
        <item name="android:statusBarColor">@color/atheer_primary</item>
        <item name="android:navigationBarColor">@color/atheer_primary</item>
    </style>
    <style name="Theme.AtheerDemo.Translucent" parent="Theme.AtheerDemo">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>
    <style name="Widget.AtheerDemo.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/atheer_primary</item>
    </style>
    <style name="Widget.AtheerDemo.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>
    <style name="Widget.AtheerDemo.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/atheer_primary</item>
        <item name="hintTextColor">@color/atheer_primary</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>
